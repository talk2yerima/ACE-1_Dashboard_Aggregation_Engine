# Copy this file to .env and fill in your values
# Then run setup.bat to install as a Windows Service.

# Date mode: TODAY | DAILY | WEEKLY | MONTHLY | QUARTERLY | YEARLY | CUSTOM
DATE_MODE=DAILY

# Override "today" for backfilling historical data (YYYY-MM-DD)
# REFERENCE_DATE=2026-05-15

# Required only when DATE_MODE=CUSTOM
# CUSTOM_START=2026-01-01
# CUSTOM_END=2026-03-31

# Override default workbook path
# RADET_FILE=./input/RADET.xlsx

# ── Azure Blob Storage ────────────────────────────────────────────────────────
# Connection string: Azure Portal -> Storage Account -> Security + networking -> Access keys
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=YOUR_ACCOUNT_NAME;AccountKey=YOUR_ACCOUNT_KEY;EndpointSuffix=core.windows.net

# Source container: engine downloads the most recently modified .xlsx from here before each run
AZURE_RADET_SOURCE_CONTAINER=combine-radets-xls

# Output container: DashboardSummary.csv is uploaded here after each run
AZURE_STORAGE_CONTAINER=powerbi-datasource

# Target workbook: daily cumulative targets used to create DashboardTargets.csv
AZURE_TARGET_CONTAINER=powerbi-datasource
AZURE_TARGET_BLOB=ACE-1_Targets.xlsx
# Optional local override for testing:
# TARGET_FILE=./input/ACE-1_Targets.xlsx

# Optional: blob name prefix / subfolder (e.g. "radet/" uploads as radet/DashboardSummary.csv)
# AZURE_STORAGE_BLOB_PREFIX=radet/

# ── Service Schedule ──────────────────────────────────────────────────────────
# Comma-separated hours (24h) when the engine runs each day.
# Default: 09:00, 11:00, 13:00, 15:00, 17:00, 19:00, 21:00
RUN_SCHEDULE=9,11,13,15,17,19,21

# Run immediately once when the Windows Service starts or restarts.
# Keep true for first deployment and manual service restarts.
RUN_ON_START=true
